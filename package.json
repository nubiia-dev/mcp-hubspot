{
  "name": "@nubiia/mcp-hubspot",
  "version": "0.4.0",
  "description": "HubSpot MCP server for AI assistants like Claude: contacts, deals, pipelines, owners, custom objects, engagements, and CRM automation. Built by Nubiia.",
  "type": "module",
  "bin": {
    "mcp-hubspot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run clean && npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hubspot",
    "hubspot-api",
    "hubspot-mcp",
    "crm",
    "crm-api",
    "sales",
    "deals",
    "contacts",
    "pipelines",
    "automation",
    "ai",
    "llm",
    "claude",
    "anthropic",
    "nubiia"
  ],
  "author": {
    "name": "Nubiia",
    "email": "hola@nubiia.es",
    "url": "https://nubiia.es"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nubiia-dev/mcp-hubspot.git"
  },
  "bugs": {
    "url": "https://github.com/nubiia-dev/mcp-hubspot/issues"
  },
  "homepage": "https://nubiia.es",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bottleneck": "^2.19.5",
    "winston": "^3.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.2",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
